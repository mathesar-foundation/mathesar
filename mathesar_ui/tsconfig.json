{
  "extends": "@tsconfig/svelte/tsconfig.json",

  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,

    "baseUrl": ".",
    "paths": {
      "@mathesar/*": ["src/*"],
      "@mathesar-component-library-dir/*": ["src/component-library/*"],
      "@mathesar-component-library/types": [
        "src/component-library/types.ts"
      ],
      "@mathesar-component-library": [
        "src/component-library/index.ts"
      ]
    },

    "declaration": false,
    "skipLibCheck": true
  },

  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.svelte",
    "*.cjs",
    "*.config.js",
    "src/**/*.json"
  ],
  "exclude": ["src/**/*.stories.svelte"]
}
