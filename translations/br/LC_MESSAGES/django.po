#: mathesar/templates/installation/complete_installation.html:3
msgid "Finalizing Installation..."
msgstr "Finalizando a Instalação..."

#: mathesar/templates/installation/complete_installation.html:5
#: mathesar/templates/installation/complete_installation.html:268
msgid "Complete Installation"
msgstr "Instalação Completa"

#: mathesar/templates/installation/complete_installation.html:129
msgid "Finish Setting Up Mathesar"
msgstr "Terminando de Configurar o Mathesar"

#: mathesar/templates/installation/complete_installation.html:132
msgid "Welcome to Mathesar!"
msgstr "Bem-Vindo ao Mathesar!"

#: mathesar/templates/installation/complete_installation.html:135
msgid ""
"Create an Admin user to start using Mathesar. You can also choose to share "
"anonymous data to help us improve."
msgstr ""
"Crie uma conta de administrador para começar a usar o Mathesar. "
"Você pode escolher compartilhar informações anonimamente para nos ajudar a melhorar"

#: mathesar/templates/installation/complete_installation.html:142
msgid "Create Admin User"
msgstr "Crie um Usuário Administrador"

#: mathesar/templates/installation/complete_installation.html:144
msgid ""
"Set up an Admin user account. This account will have full control over your "
"Mathesar installation."
msgstr ""
"Configure uma conta de Administrador. Essa conta terá total controle sobe a "
"sua instalação do Mathesar"

#: mathesar/templates/installation/complete_installation.html:153
#: mathesar/templates/registration/login.html:16
msgid "Username"
msgstr "Usuário"

#: mathesar/templates/installation/complete_installation.html:170
#: mathesar/templates/registration/login.html:37
msgid "Password"
msgstr "Senha"

#: mathesar/templates/installation/complete_installation.html:180
msgid "Confirm Password"
msgstr "Confirme a Senha"

#: mathesar/templates/installation/complete_installation.html:193
msgid "Your password must be at least 8 characters long."
msgstr "A sua senha deve ter no mínimo 8 caracteres"

#: mathesar/templates/installation/complete_installation.html:194
msgid "We recommend a mix of letters, numbers, and symbols for added security."
msgstr "Nós recomendamos uma mistura de letras, números e símbolos para mais segurança"

#: mathesar/templates/installation/complete_installation.html:228
msgid "Support Mathesar's Growth"
msgstr "Suporte o crescimento do Mathesar"

#: mathesar/templates/installation/complete_installation.html:237
msgid "Send a one-time confirmation to let us know you've installed Mathesar"
msgstr "Envie uma confirmação apenas uma vez para nós sabermos que você instalou o Mathesar"

#: mathesar/templates/installation/complete_installation.html:240
msgid "Let our open-source team know we have real users out there."
msgstr "Deixe o nosso time open-source saber que nós temos usuários reais."

#: mathesar/templates/installation/complete_installation.html:241
msgid ""
"No personal data is shared, just an acknowledgment of your installation."
msgstr ""
"Nenhuma informação pessoal é compartilhada, apenas a existência da sua instalação."

#: mathesar/templates/installation/complete_installation.html:243
#: mathesar/templates/installation/complete_installation.html:259
msgid "See what's shared."
msgstr "Veja o que é compartilhado."

#: mathesar/templates/installation/complete_installation.html:253
msgid "Enable anonymous usage data collection"
msgstr "Ative o compartilhamento de uso anônimo"

#: mathesar/templates/installation/complete_installation.html:256
msgid "Share anonymous usage data periodically to help us improve features."
msgstr "Compartilhe informações de uso anônimo para nos ajudar a melhorar."

#: mathesar/templates/installation/complete_installation.html:257
msgid "No personal data is collected, and you can change this setting anytime."
msgstr ""
"Nenhuma informação pessoal é coletada, você pode mudar essa configuração "
"a qualquer momento."

#: mathesar/templates/mathesar/login_base.html:4
msgid "Login"
msgstr "Entrar"

#: mathesar/templates/registration/login.html:3
msgid "Logging In..."
msgstr "Entrando..."

#: mathesar/templates/registration/login.html:5
msgid "Log in to Mathesar"
msgstr "Entre no Mathesar"

#: mathesar/templates/registration/login.html:65
msgid "Log In"
msgstr "Entrar"

#: mathesar/templates/users/password_reset_confirmation.html:4
msgid "Update Your Password"
msgstr "Atualize a Sua Senha"

#: mathesar/templates/users/password_reset_confirmation.html:8
msgid ""
"Since your password was set by an administrator, you need to update your "
"password to continue."
msgstr ""
"A sua senha foi criada por um administrador, você precisa atualizar ela "
"para continuar"

#: mathesar/templates/users/password_reset_confirmation.html:14
msgid "New Password"
msgstr "Nova Senha"

#: mathesar/templates/users/password_reset_confirmation.html:41
msgid "Confirm"
msgstr "Confirmar"

#: mathesar/templates/users/password_reset_confirmation.html:67
msgid "Update Password"
msgstr "Atualizar Senha"

#: mathesar/templates/users/password_reset_confirmation.html:71
msgid "After updating your password, you'll need to log in again."
msgstr "Depois de atualizar a sua senha, você precisa entrar novamente."

#: mathesar/templates/users/password_reset_confirmation.html:76
msgid ""
"The password reset link was invalid, possibly because it has already been "
"used.  Please request a new password reset."
msgstr ""
"O link para mudar a senha era inválido, provavelmente por ter sido usado.  "
"Por favor solicite a mudança de senha novamente."

#: mathesar/views/users/password_reset.py:24
msgid "Change Default Password"
msgstr "Mudar a Senha Padrão"
